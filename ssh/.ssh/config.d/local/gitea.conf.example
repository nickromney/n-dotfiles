# Local Gitea over a Kind/NodePort-style loopback SSH endpoint.
#
# Copy to ~/.ssh/config.d/local/gitea.conf and adjust the hostname, port, key,
# or aliases for the local cluster you are targeting.

Host gitea-local
  HostName 127.0.0.1
  Port 30022
  User git
  IdentityFile ~/.ssh/id_ed25519
  IdentitiesOnly yes

Host gitea.admin.127.0.0.1.sslip.io
  HostName gitea.admin.127.0.0.1.sslip.io
  Port 30022
  User git
  IdentityFile ~/.ssh/id_ed25519
  IdentitiesOnly yes
